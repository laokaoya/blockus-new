# Server Configuration
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# JWT Secret (for guest tokens; auto-generated in dev mode)
# JWT_SECRET=your-strong-secret

# Firebase Admin — use ONE of the following methods:

# Method 1: Inline JSON (recommended for deployment platforms like Railway/Render)
# 重要：project_id 必须与前端 Firebase 配置一致！前端用 blockus-14f38 则此处也需 blockus-14f38 的凭证
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"blockus-14f38",...}

# Method 2: File path (for local development)
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Method 3: Project ID only (uses Application Default Credentials)
# FIREBASE_PROJECT_ID=your-project-id

# Email (for verification codes on registration)
# Option 1: Resend (recommended, no SMTP needed)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM=Blockus <onboarding@resend.dev>

# Option 2: SMTP (QQ/163/Gmail etc.)
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your@email.com
# SMTP_PASS=your-auth-code
# SMTP_FROM=Blockus <your@email.com>

# If neither is set, codes are logged to console (dev mode)
